# ──────────────────────────────────────────────────────────
# htlc-orchestrator environment
# Copy to .env (or pass via shell) before `npm run dev`.
# ──────────────────────────────────────────────────────────

# Server
PORT=4000
HOST=0.0.0.0
DB_PATH=./swaps.db
LOG_LEVEL=info

# Network
MIDNIGHT_NETWORK=preprod
BLOCKFROST_API_KEY=

# OTC layer — Supabase (server-side, service role key — NEVER ship to clients)
# When unset, /api/auth/* + /api/users/* + /api/rfqs/* return 503 and the
# orchestrator continues to serve the legacy /api/swaps surface unauthenticated
# (preserves the existing two-browser paste-bundle flow).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# CORS (additional comma-separated origins beyond localhost defaults)
CORS_ORIGINS=

# Stuck-swap alerter (optional)
# STUCK_SWAP_WEBHOOK_URL=
# STUCK_SWAP_SCAN_INTERVAL_MS=60000
# STUCK_SWAP_ALICE_CLAIMED_STALE_MS=900000
# STUCK_SWAP_REALERT_MS=21600000
# STUCK_SWAP_PUBLIC_UI_URL=
