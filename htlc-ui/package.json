{
  "name": "@midnight-ntwrk/htlc-ui",
  "version": "0.1.0",
  "author": "IOG",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "copy-zk-assets": "rm -rf ./public/keys ./public/zkir && mkdir -p ./public/keys ./public/zkir && cp ../contract/src/managed/htlc/keys/* ./public/keys/ && cp ../contract/src/managed/htlc/zkir/* ./public/zkir/ && cp ../contract/src/managed/usdc/keys/* ./public/keys/ && cp ../contract/src/managed/usdc/zkir/* ./public/zkir/ && cp ../cardano/plutus.json ./public/plutus.json",
    "predev": "npm run copy-zk-assets",
    "prebuild": "npm run copy-zk-assets",
    "build": "rm -rf ./dist && tsc && vite build --mode preprod",
    "fix-libsodium": "mkdir -p ../node_modules/libsodium-wrappers-sumo/dist/modules-sumo-esm && rm -f ../node_modules/libsodium-wrappers-sumo/dist/modules-sumo-esm/libsodium-sumo.mjs && cp ../node_modules/libsodium-sumo/dist/modules-sumo-esm/libsodium-sumo.mjs ../node_modules/libsodium-wrappers-sumo/dist/modules-sumo-esm/libsodium-sumo.mjs",
    "build:vercel": "npm run fix-libsodium && rm -rf ./dist && tsc && vite build --mode preprod",
    "vercel-build": "rm -rf ./dist && vite build --mode preprod",
    "build:preview": "rm -rf ./dist && tsc && vite build --mode preview",
    "build:start": "npm run build && npm run start",
    "build:start:preview": "npm run build:preview && npm run start",
    "ci": "npm run typecheck && npm run lint",
    "dev": "vite",
    "lint": "eslint ./src",
    "start": "http-server -c-1 --port 8080 --proxy http://localhost:8080? ./dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "preview": "vite preview",
    "prepack": "yarn build"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@harmoniclabs/bytestring": "^1.0.0",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.8",
    "@supabase/supabase-js": "^2.45.0",
    "node-stdlib-browser": "^1.3.1",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "7.13.0"
  },
  "devDependencies": {
    "@swc/core": "^1.15.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint-plugin-react": "^7.37.5",
    "vite": "^7.3.1",
    "vite-plugin-node-polyfills": "^0.25.0",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.5.0"
  }
}
